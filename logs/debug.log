    dbo.courses c1_0 
left join
    dbo.course_registrations cr1_0 
        on cr1_0.course_id=c1_0.course_id 
join
    dbo.course_departments cd1_0 
        on cd1_0.course_department_id=c1_0.course_department_id 
where
    (
        ? is null 
        or c1_0.course_department_id=?
    ) 
group by
    c1_0.course_id,
    c1_0.course_name,
    c1_0.course_code,
    c1_0.capacity,
    cd1_0.course_department_name
